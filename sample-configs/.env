# <service>_VERSION values are from Docker Hub

##########
# IMMICH
##########
IMMICH_VERSION=v2.7.5
# You can find documentation for all the supported env variables at https://immich.app/docs/install/environment-variables

UPLOAD_LOCATION=./data/immich/library    # The location where your uploaded files are stored
DB_DATA_LOCATION=./data/immich/postgres  # The location where your database files are stored

# Please use only the characters `A-Za-z0-9`, without special characters or spaces
DB_PASSWORD=postgres
DB_USERNAME=postgres
DB_NAME=immich
EXTERNAL_LIB=./data/immich-lib-ext

# Duplicati
SETTINGS_ENCRYPTION_KEY=password
DUPLICATI__WEBSERVICE_PASSWORD=password

##########
# Jellyfin
##########
STREAM_EXT_LIB=./data/jellyfin/media-ext
